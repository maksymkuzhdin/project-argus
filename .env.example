# ──────────────────────────────────────────────
# Project Argus — Environment Variables
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=argus
POSTGRES_PASSWORD=argus_local
POSTGRES_DB=argus

# SQLAlchemy connection string (used by backend)
DATABASE_URL=postgresql://argus:argus_local@db:5432/argus

# NAZK public declarations API
NAZK_API_BASE_URL=https://public-api.nazk.gov.ua/v2
NAZK_CONCURRENCY=3
NAZK_RETRY_ATTEMPTS=3
NAZK_PAGE_DELAY_SECONDS=0.3
NAZK_TIMEOUT_SECONDS=30

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
